# Argia_Mont v2 — environment variables
# Copy this file to ~/.argia_mont.env on the Pi, fill in the real values,
# then `chmod 600 ~/.argia_mont.env` so only you can read it.
#
# Source it from your shell or the cron entry:
#   set -a; source ~/.argia_mont.env; set +a
#
# NEVER commit this file with real values.

# === Google Sheets (REQUIRED) ===

# The sheet ID from your Argia_Mont_v2 sheet URL:
# docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID_V2=

# Service account JSON as a single-line string.
# Tip: cat service_account.json | tr -d '\n' to flatten it.
GOOGLE_CREDENTIALS=

# === Growatt (prefer API token; web UI as fallback) ===
GROWATT_API_TOKEN=
GROWATT_USERNAME=
GROWATT_PASSWORD=

# === Huawei FusionSolar (required if any HUAWEI plants active) ===
HUAWEI_USERNAME=
HUAWEI_PASSWORD=

# === SolarEdge (required if any SOLAREDGE plants active) ===
SOLAREDGE_API_KEY=

# === Optional tuning ===
# LOG_LEVEL=INFO
# OPEN_METEO_TIMEOUT=25
