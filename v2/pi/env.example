# ~/.argia_env ALREADY EXISTS on the Pi and belongs to v1 (run_sync.sh
# sources it). Do NOT copy this file over it. APPEND only the variables
# below that are missing — check first with:
#   grep -E '^(GOOGLE_SHEET_ID_V2|GROWATT_USERNAME)=' ~/.argia_env
# Values mirror the GitHub Actions secrets 1:1. If a name already exists
# with the same value (likely for vendor credentials), skip it.
GOOGLE_SHEET_ID_V2=1ZCRgoV9F4srri1lATZHukgsUmRForZcuJb78LLM3REE
GOOGLE_SHEET_ID=            # v1 sheet id — only until v1 retires
GOOGLE_CREDENTIALS_FILE=/home/zemel/secrets/argia-service-account.json
GROWATT_USERNAME=
GROWATT_PASSWORD=
HUAWEI_USERNAME=
HUAWEI_PASSWORD=
SOLAREDGE_API_KEY=
SMA_CLIENT_ID=
SMA_CLIENT_SECRET=
GCS_DASHBOARD_BUCKET=argia-pv-dashboard
GOOGLE_ARCHIVE_FOLDER_ID=
ARGIA_REPO=/home/zemel/argia_v2
ARGIA_LOG_DIR=/home/zemel/argia_logs
